{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "build#skip-types": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "env": ["TSC_SKIP_TYPES"]
    }
  },
  "globalEnv": ["TSC_SKIP_TYPES"]
}