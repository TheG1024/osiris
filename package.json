{
  "name": "osiris-redux",
  "version": "0.0.1",
  "private": true,
  "description": "Planetary-scale geospatial intelligence platform",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "nanoid": "^5.1.11",
    "non-secure": "^0.0.1-security",
    "picocolors": "^1.1.1",
    "prettier": "^3.0.0",
    "source-map-js": "^1.2.1",
    "ts-node": "^10.9.2",
    "turbo": "latest"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.17.0"
  }
}
